---
export interface Props {
  pillar: 'arte' | 'ciencia' | 'consciencia';
  locale?: string;
}

const { pillar, locale = 'es' } = Astro.props;

const glyphs = {
  arte: '◐',
  ciencia: '✧',
  consciencia: '❍',
};

const labels = {
  arte:         { es: 'Arte',         en: 'Art' },
  ciencia:      { es: 'Ciencia',      en: 'Science' },
  consciencia:  { es: 'Consciencia',  en: 'Consciousness' },
};

const pillarVar = `--color-pillar-${pillar}`;

const styles = {
  backgroundColor: `rgb(from var(${pillarVar}) r g b / 0.1)`,
  color: `var(${pillarVar})`,
  borderColor: `rgb(from var(${pillarVar}) r g b / 0.3)`,
};
---

<span
  class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-bitacora border"
  style={styles}
>
  <span class="font-headline text-sm leading-none" aria-hidden="true">{glyphs[pillar]}</span>
  {locale === 'en' ? labels[pillar].en : labels[pillar].es}
</span>
