---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import CelestialLine from '../../components/CelestialLine.astro';
import GlassPanel from '../../components/GlassPanel.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import PillarBadge from '../../components/PillarBadge.astro';

const locale = Astro.currentLocale || 'es';
const t = (es: string, en: string) => (locale === 'en' ? en : es);

const projects = await getCollection('projects');
const completed = projects.filter((p) => p.data.status === 'completed');
const inDev = projects.filter((p) => p.data.status === 'in_development');
const featured = completed.find((p) => p.data.featured);

const pillars = [
  {
    icon: 'palette',
    title: t('Arte', 'Art'),
    desc: t(
      'Expresiones creativas que amplían los límites de la percepción y conectan con la belleza esencial de la existencia.',
      'Creative expressions that expand the boundaries of perception and connect with the essential beauty of existence.'
    ),
    key: 'arte' as const,
  },
  {
    icon: 'science',
    title: t('Ciencia', 'Science'),
    desc: t(
      'Investigación rigurosa que ilumina los misterios del cosmos y nuestra posición en la trama de la vida.',
      'Rigorous research that illuminates the mysteries of the cosmos and our place within the web of life.'
    ),
    key: 'ciencia' as const,
  },
  {
    icon: 'psychology',
    title: t('Consciencia', 'Consciousness'),
    desc: t(
      'Exploración del espíritu humano y el despertar colectivo hacia una nueva forma de habitar el planeta.',
      'Exploration of the human spirit and collective awakening toward a new way of inhabiting the planet.'
    ),
    key: 'consciencia' as const,
  },
];
---

<BaseLayout
  title={t('Inicio', 'Home')}
  description={t(
    'Nautas — Asociación argentina dedicada a la integración del arte, la ciencia y la consciencia humana.',
    'Nautas — Argentine association dedicated to the integration of art, science, and human consciousness.'
  )}
  locale={locale}
>
  <!-- Hero -->
  <HeroSection
    variant="split"
    eyebrow={t('La Asociación Argentina', 'The Argentine Association')}
    title={`${t('Navegando el ', 'Navigating the ')}<em>${t('Cosmos', 'Cosmos')}</em>${t(' de la Ciencia Consciente.', ' of Conscious Science.')}`}
    subtitle={t(
      'Nautas es una asociación argentina dedicada a cerrar la brecha entre la exploración científica, la expresión artística y la conciencia humana.',
      'Nautas is an Argentine association dedicated to bridging the gap between scientific exploration, artistic expression, and human consciousness.'
    )}
  >
    <div class="flex gap-4 pt-4">
      <a
        href={`/${locale === 'en' ? 'en/' : ''}proyectos`}
        class="bg-primary text-on-primary px-6 py-3 rounded font-label text-xs uppercase tracking-widest hover:brightness-110 active:scale-95 transition-all"
      >
        {t('Ver Proyectos', 'View Projects')}
      </a>
      <a
        href={`/${locale === 'en' ? 'en/' : ''}institucional`}
        class="border border-primary/30 text-primary px-6 py-3 rounded font-label text-xs uppercase tracking-widest hover:bg-primary/10 transition-all"
      >
        {t('Quiénes Somos', 'About Us')}
      </a>
    </div>
  </HeroSection>

  <CelestialLine />

  <!-- Three Pillars -->
  <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-32">
    <h2 class="font-headline text-4xl md:text-5xl text-center mb-16">
      {t('Tres Pilares, Un Universo', 'Three Pillars, One Universe')}
    </h2>
    <div class="grid md:grid-cols-3 gap-8">
      {pillars.map((p) => (
        <div class="group p-8 md:p-10 rounded-2xl bg-surface-container-low border border-outline-variant/10 hover:bg-surface-container-high transition-all duration-300">
          <div class="w-14 h-14 rounded-full bg-primary-container flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <span class="material-symbols-outlined text-2xl text-primary">{p.icon}</span>
          </div>
          <h3 class="font-headline text-2xl mb-4">{p.title}</h3>
          <p class="text-on-surface-variant leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured Production -->
  {featured && (
    <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-32">
      <h2 class="font-headline text-4xl md:text-5xl mb-12">
        {t('Producción Destacada', 'Featured Production')}
      </h2>
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="aspect-video rounded-xl overflow-hidden bg-surface-container-lowest relative">
          {featured.data.playlistId ? (
            <iframe
              src={`https://www.youtube.com/embed/videoseries?list=${featured.data.playlistId}`}
              title={featured.data.title}
              class="absolute inset-0 w-full h-full"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          ) : (
            <div class="w-full h-full flex items-center justify-center">
              <span class="material-symbols-outlined text-8xl text-primary/20">movie</span>
            </div>
          )}
        </div>
        <div class="space-y-6">
          <div class="flex items-center gap-3">
            <PillarBadge pillar={featured.data.pillar} locale={locale} />
            <span class="font-label text-xs uppercase tracking-widest text-on-surface-variant">{featured.data.kind}</span>
          </div>
          <h3 class="font-headline text-4xl md:text-5xl">{featured.data.title}</h3>
          <p class="text-lg text-on-surface-variant leading-relaxed">{t(featured.data.tagline.es, featured.data.tagline.en)}</p>
          <p class="text-on-surface-variant/70 leading-relaxed line-clamp-3">{t(featured.data.description.es, featured.data.description.en)}</p>
          <a
            href={`/${locale === 'en' ? 'en/' : ''}proyectos/${featured.id}`}
            class="inline-flex items-center gap-2 text-primary font-label text-xs uppercase tracking-widest hover:gap-3 transition-all"
          >
            {t('Ver Proyecto', 'View Project')}
            <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Completed Productions Grid -->
  {completed.length > 0 && (
    <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-32">
      <h2 class="font-headline text-4xl md:text-5xl mb-12">{t('Producciones', 'Productions')}</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {completed.map((p) => (
          <ProjectCard
            title={p.data.title}
            slug={p.id}
            kind={p.data.kind}
            pillar={p.data.pillar}
            tagline={t(p.data.tagline.es, p.data.tagline.en)}
            year={p.data.year}
            episodeCount={p.data.episodes?.length}
            image={p.data.heroImage}
            status="completed"
            locale={locale}
          />
        ))}
      </div>
    </section>
  )}

  <!-- In Development -->
  {inDev.length > 0 && (
    <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-32">
      <h2 class="font-headline text-4xl md:text-5xl mb-12">{t('En Desarrollo', 'In Development')}</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {inDev.map((p) => (
          <ProjectCard
            title={p.data.title}
            slug={p.id}
            kind={p.data.kind}
            pillar={p.data.pillar}
            tagline={t(p.data.tagline.es, p.data.tagline.en)}
            status="in_development"
            locale={locale}
            variant="horizontal"
          />
        ))}
      </div>
    </section>
  )}

  <!-- Vision Quote -->
  <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-20">
    <GlassPanel padding="xl">
      <div class="text-center max-w-3xl mx-auto">
        <span class="material-symbols-outlined text-primary text-5xl mb-8 block">format_quote</span>
        <blockquote class="font-headline text-2xl md:text-3xl italic text-on-surface leading-relaxed mb-8">
          {t(
            '"Observar es participar. Somos el universo experimentándose a sí mismo a través del lente de la ciencia y el alma."',
            '"To observe is to participate. We are the universe experiencing itself through the lens of science and the soul."'
          )}
        </blockquote>
        <div class="celestial-line max-w-xs mx-auto"></div>
      </div>
    </GlassPanel>
  </section>

  <!-- Newsletter CTA -->
  <section class="max-w-[1200px] mx-auto px-6 md:px-12 mb-20 text-center py-24 md:py-32 bg-nebula rounded-3xl relative overflow-hidden">
    <div class="absolute inset-0 opacity-5 pointer-events-none">
      <svg viewBox="0 0 100 100" class="w-full h-full">
        <circle cx="50" cy="50" fill="none" r="40" stroke="currentColor" class="text-primary"></circle>
        <circle cx="50" cy="50" fill="none" r="20" stroke="currentColor" class="text-primary"></circle>
      </svg>
    </div>
    <div class="relative z-10">
      <h2 class="font-headline text-4xl md:text-5xl mb-8">
        {t('¿Listo para mapear lo desconocido?', 'Ready to map the unknown?')}
      </h2>
      <p class="text-on-surface-variant text-lg md:text-xl max-w-2xl mx-auto mb-10">
        {t(
          'Suscríbete a nuestro boletín para recibir bitácoras celestiales mensuales, avances científicos e invitaciones a eventos exclusivos.',
          'Subscribe to our newsletter for monthly celestial logs, scientific breakthroughs, and invitations to exclusive events.'
        )}
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-3 max-w-md mx-auto">
        <input
          class="bg-transparent border-b border-outline-variant/30 focus:border-primary focus:ring-0 text-on-surface py-3 px-4 outline-none transition-all flex-grow placeholder:text-on-surface/30"
          placeholder={t('estelar@navegante.com', 'stellar@navigator.com')}
          type="email"
        />
        <button class="bg-primary text-on-primary px-8 py-3 rounded font-label text-xs uppercase tracking-[0.2em] whitespace-nowrap hover:brightness-110 transition-all">
          {t('Suscribirse', 'Subscribe')}
        </button>
      </div>
    </div>
  </section>
</BaseLayout>
