---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import CelestialLine from '../../components/CelestialLine.astro';
import GlassPanel from '../../components/GlassPanel.astro';
import TeamCard from '../../components/TeamCard.astro';

const locale = Astro.currentLocale || 'es';
const pageSlug = locale === 'en' ? 'en/institucional' : 'institucional';
const page = await getEntry('pages', pageSlug);
const d = page?.data;

const team = await getCollection('team');
team.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={d?.title ?? ''} description={d?.description ?? ''} locale={locale}>
  <!-- Hero -->
  <HeroSection
    variant="centered"
    title={d?.hero_title ?? ''}
    subtitle={d?.hero_subtitle}
  />

  <CelestialLine />

  <!-- Mission / Propósito -->
  <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-32">
    <p class="font-bitacora italic text-warm text-sm mb-6">
      // {locale === 'en' ? 'mission' : 'misión'}
    </p>
    <div class="grid md:grid-cols-12 gap-12">
      <div class="md:col-span-5">
        <h2 class="font-headline text-4xl md:text-5xl mb-8 md:sticky md:top-32 [&_em]:italic [&_em]:text-warm">
          <Fragment set:html={d?.mission_title ?? ''} />
        </h2>
        <div class="aspect-square rounded-full border border-warm/20 p-8 relative flex items-center justify-center">
          <div class="absolute inset-0 bg-warm/[0.04] rounded-full animate-pulse"></div>
          <div class="text-center relative z-10">
            <span class="font-headline text-warm/60 text-7xl block mb-4 leading-none" aria-hidden="true">✦</span>
            <p class="font-bitacora italic text-warm text-xs">
              // {locale === 'en' ? 'cultural evolution' : 'evolución cultural'}
            </p>
          </div>
        </div>
      </div>
      <div class="md:col-span-7 space-y-8">
        <GlassPanel>
          <div class="space-y-6 text-on-surface-variant leading-relaxed">
            {d?.mission_p1 && (
              <p class="text-xl text-on-surface leading-relaxed mb-8 font-headline italic">{d.mission_p1}</p>
            )}
            {d?.mission_p2 && <p>{d.mission_p2}</p>}
            {d?.mission_p3 && <p>{d.mission_p3}</p>}
            {d?.mission_p4 && <p>{d.mission_p4}</p>}
            {d?.mission_p5 && <p>{d.mission_p5}</p>}
            {d?.mission_cta && (
              <p class="text-warm font-headline italic text-lg">{d.mission_cta}</p>
            )}
          </div>
        </GlassPanel>
      </div>
    </div>
  </section>

  <CelestialLine />

  <!-- Vision -->
  <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-32">
    <p class="font-bitacora italic text-warm text-sm mb-6">
      // {locale === 'en' ? 'vision' : 'visión'}
    </p>
    <div class="bg-surface-container-lowest rounded-3xl overflow-hidden border border-warm/10">
      <div class="grid md:grid-cols-2">
        <div class="p-8 md:p-16 lg:p-20 flex flex-col justify-center">
          <h2 class="font-headline text-4xl md:text-5xl mb-10 [&_em]:italic [&_em]:text-warm">
            <Fragment set:html={d?.vision_title ?? ''} />
          </h2>
          <div class="space-y-6 text-on-surface-variant leading-relaxed text-base md:text-lg">
            {d?.vision_p1 && <p>{d.vision_p1}</p>}
            {d?.vision_p2 && <p>{d.vision_p2}</p>}
            {d?.vision_p3 && <p>{d.vision_p3}</p>}
          </div>
        </div>
        <div class="relative bg-surface-container-high flex flex-col items-center justify-center p-8 md:p-16 lg:p-20 text-center border-l border-warm/10">
          <div class="mb-10 relative z-10">
            <span class="font-headline text-warm/50 text-6xl block mb-6 leading-none" aria-hidden="true">⊙</span>
            {d?.vision_blockquote && (
              <blockquote class="font-headline text-2xl md:text-3xl italic text-on-surface mb-6">
                {d.vision_blockquote}
              </blockquote>
            )}
          </div>
          <div class="space-y-6 text-sm text-on-surface-variant leading-relaxed text-left relative z-10">
            {d?.vision_p4 && <p>{d.vision_p4}</p>}
            {d?.vision_p5 && <p>{d.vision_p5}</p>}
          </div>
          <!-- Dashed circle background decoration -->
          <div class="absolute inset-0 opacity-[0.08] text-warm pointer-events-none overflow-hidden" aria-hidden="true">
            <svg class="w-full h-full" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
              <circle cx="50" cy="50" r="45" fill="none" stroke="currentColor" stroke-dasharray="1 4"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CelestialLine />

  <!-- Team -->
  <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-32">
    <p class="font-bitacora italic text-warm text-sm mb-6">
      // {locale === 'en' ? 'team' : 'equipo'}
    </p>
    <div class="flex flex-col md:flex-row justify-between items-end mb-14">
      <div class="max-w-xl">
        <h2 class="font-headline text-4xl md:text-5xl mb-4 [&_em]:italic [&_em]:text-warm">
          <Fragment set:html={d?.team_title ?? ''} />
        </h2>
        <p class="text-on-surface-variant text-lg">
          {d?.team_subtitle ?? ''}
        </p>
      </div>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {team.map((member, i) => (
        <div class={i % 2 === 1 ? 'lg:mt-12' : ''}>
          <TeamCard
            name={member.data.name}
            role={locale === 'en' ? member.data.role.en : member.data.role.es}
            photo={member.data.photo}
            bio={member.data.bio ? (locale === 'en' ? member.data.bio.en : member.data.bio.es) : undefined}
          />
        </div>
      ))}
    </div>
  </section>

  <CelestialLine />

  <!-- CTA -->
  <section class="max-w-[1200px] mx-auto px-6 md:px-12 mb-20 text-center py-24 md:py-32 bg-nebula rounded-3xl relative overflow-hidden">
    <div class="relative z-10">
      <p class="font-bitacora italic text-warm text-sm mb-6">
        // {locale === 'en' ? 'set sail' : 'embarcate'}
      </p>
      <h2 class="font-headline text-4xl md:text-5xl mb-8 [&_em]:italic [&_em]:text-warm">
        <Fragment set:html={d?.cta_title ?? ''} />
      </h2>
      <p class="text-on-surface-variant text-lg md:text-xl max-w-2xl mx-auto mb-10">
        {d?.cta_subtitle ?? ''}
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href={`/${locale === 'en' ? 'en/' : ''}contacto`}
          class="group inline-flex items-center justify-center gap-2 px-8 py-3 rounded-full bg-warm text-on-warm font-bitacora text-sm hover:-translate-y-0.5 hover:shadow-[0_8px_24px_-8px_rgb(from_var(--color-warm)_r_g_b_/_0.5)] transition-all"
        >
          {locale === 'en' ? 'Contact us' : 'Contactanos'}
          <span class="transition-transform group-hover:translate-x-1">→</span>
        </a>
        <a
          href={`/${locale === 'en' ? 'en/' : ''}proyectos`}
          class="group inline-flex items-center justify-center gap-2 px-8 py-3 rounded-full border border-warm/40 text-warm font-bitacora text-sm hover:border-warm hover:bg-warm/[0.06] hover:-translate-y-0.5 transition-all"
        >
          {locale === 'en' ? 'View projects' : 'Ver proyectos'}
          <span class="transition-transform group-hover:translate-x-1">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
