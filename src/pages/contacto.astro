---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import CelestialLine from '../components/CelestialLine.astro';

const locale = Astro.currentLocale || 'es';
const pageSlug = locale === 'en' ? 'en/contacto' : 'contacto';
const page = await getEntry('pages', pageSlug);
const d = page?.data;
---

<BaseLayout
  title={d?.title ?? ''}
  description={d?.description ?? ''}
  locale={locale}
>
  <section class="max-w-[1440px] mx-auto px-6 md:px-12 pt-32 pb-16">
    <div class="grid md:grid-cols-2 gap-16">
      {/* Left: Info */}
      <div>
        <h1 class="font-headline text-5xl md:text-7xl leading-tight mb-4">
          {d?.hero_title ?? ''}
        </h1>
        <p class="font-headline italic text-xl text-on-surface-variant mb-12">
          {d?.contact_tagline ?? ''}
        </p>

        <div class="space-y-8">
          <div>
            <span class="font-label text-xs uppercase tracking-widest text-tertiary block mb-1">
              {d?.email_label ?? 'Email'}
            </span>
            <a href={`mailto:${d?.email ?? 'contacto@nautas.org'}`} class="text-xl text-on-surface hover:text-primary transition-colors">
              {d?.email ?? 'contacto@nautas.org'}
            </a>
          </div>

          <div>
            <span class="font-label text-xs uppercase tracking-widest text-tertiary block mb-1">
              {d?.youtube_label ?? 'YouTube'}
            </span>
            <a href={d?.youtube_url ?? 'https://youtube.com/@Nautas'} target="_blank" rel="noopener noreferrer" class="text-xl text-on-surface hover:text-primary transition-colors">
              {d?.youtube_display ?? 'youtube.com/@Nautas'}
            </a>
          </div>

          <div>
            <span class="font-label text-xs uppercase tracking-widest text-tertiary block mb-1">
              {d?.location_label ?? (locale === 'en' ? 'Location' : 'Ubicación')}
            </span>
            <p class="text-xl text-on-surface">
              {d?.location ?? 'Buenos Aires, Argentina'}
            </p>
          </div>

          <div>
            <span class="font-label text-xs uppercase tracking-widest text-tertiary block mb-1">
              {d?.response_label ?? (locale === 'en' ? 'Response Time' : 'Tiempo de Respuesta')}
            </span>
            <p class="text-on-surface-variant">
              {d?.response_time ?? (locale === 'en' ? '3-5 business days' : '3 a 5 días hábiles')}
            </p>
          </div>
        </div>

        <CelestialLine />

        {/* Social */}
        <div class="flex gap-6">
          <a href="https://instagram.com/nautas" target="_blank" rel="noopener noreferrer" class="text-on-surface-variant hover:text-primary transition-colors" aria-label="Instagram">
            <span class="material-symbols-outlined text-3xl">photo_camera</span>
          </a>
          <a href="https://facebook.com/nautas" target="_blank" rel="noopener noreferrer" class="text-on-surface-variant hover:text-primary transition-colors" aria-label="Facebook">
            <span class="material-symbols-outlined text-3xl">groups</span>
          </a>
          <a href={d?.youtube_url ?? 'https://youtube.com/@Nautas'} target="_blank" rel="noopener noreferrer" class="text-on-surface-variant hover:text-primary transition-colors" aria-label="YouTube">
            <span class="material-symbols-outlined text-3xl">play_circle</span>
          </a>
        </div>
      </div>

      {/* Right: Form */}
      <div class="glass-panel rounded-2xl p-8 md:p-12">
        <h2 class="font-headline text-2xl mb-8">
          {d?.form_title ?? (locale === 'en' ? 'Send your message' : 'Enviá tu mensaje')}
        </h2>
        <ContactForm locale={locale} />
      </div>
    </div>
  </section>
</BaseLayout>
