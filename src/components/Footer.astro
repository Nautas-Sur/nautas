---
interface Props {
  locale: string;
}

const { locale } = Astro.props;

const label = (es: string, en: string) => (locale === 'en' ? en : es);

const socialLinks = [
  { name: 'Instagram', href: 'https://instagram.com/nautas', icon: 'instagram' },
  { name: 'Facebook', href: 'https://facebook.com/nautas', icon: 'facebook' },
  { name: 'YouTube', href: 'https://youtube.com/@Nautas', icon: 'youtube' },
];

const legalLinks = [
  { es: 'Política de Privacidad', en: 'Privacy Policy', href: '#' },
  { es: 'Términos de Servicio', en: 'Terms of Service', href: '#' },
];

const navLinks = [
  { es: 'Inicio', en: 'Home', href: '/' },
  { es: 'Institucional', en: 'About', href: '/institucional' },
  { es: 'Proyectos', en: 'Projects', href: '/proyectos' },
  { es: 'Archivo', en: 'Archive', href: '/archivo' },
];

const year = new Date().getFullYear();
---

<footer class="relative w-full mt-24 pt-20 pb-10 px-6 md:px-12 border-t border-primary/[0.06]">
  <!-- Decoración: línea cálida sutil arriba -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-px bg-gradient-to-r from-transparent via-warm/30 to-transparent" aria-hidden="true"></div>

  <div class="max-w-[1440px] mx-auto">
    <!-- Grid principal -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12 mb-16">

      <!-- Brand + tagline -->
      <div class="md:col-span-5 space-y-6">
        <div class="space-y-3">
          <div class="font-headline text-2xl tracking-[0.4em] text-on-surface">NAUTAS</div>
          <p class="font-bitacora italic text-warm text-sm tracking-wide">
            {label('// desde un puerto del sur', '// from a southern port')}
          </p>
        </div>

        <p class="font-headline italic text-lg text-on-surface-variant leading-relaxed max-w-md">
          {label(
            'Tejemos arte, ciencia y consciencia desde el sur del mundo, hacia un viaje compartido.',
            'We weave art, science and consciousness from the south of the world, toward a shared journey.'
          )}
        </p>

        <!-- Redes sociales (íconos SVG) -->
        <div class="flex items-center gap-3 pt-2">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.name}
              class="group w-10 h-10 rounded-full border border-on-surface/15 flex items-center justify-center text-on-surface/60 hover:text-warm hover:border-warm hover:-translate-y-0.5 transition-all duration-300"
            >
              {link.icon === 'instagram' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-[18px] h-[18px]">
                  <rect x="3" y="3" width="18" height="18" rx="4" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" />
                </svg>
              )}
              {link.icon === 'facebook' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-[18px] h-[18px]">
                  <path d="M 14 8 L 14 6 Q 14 4 16 4 L 18 4 M 14 8 L 14 20 M 10 12 L 18 12" stroke-linecap="round" />
                </svg>
              )}
              {link.icon === 'youtube' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-[18px] h-[18px]">
                  <rect x="2" y="6" width="20" height="12" rx="2" />
                  <polygon points="10,9 16,12 10,15" fill="currentColor" />
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Spacer -->
      <div class="hidden md:block md:col-span-1"></div>

      <!-- Navegar -->
      <div class="md:col-span-2 space-y-4">
        <h4 class="font-bitacora italic text-warm text-xs uppercase tracking-[0.2em]">
          {label('// navegar', '// navigate')}
        </h4>
        <ul class="space-y-2.5">
          {navLinks.map((link) => (
            <li>
              <a
                href={locale === 'en' ? (link.href === '/' ? '/en' : `/en${link.href}`) : link.href}
                class="font-body text-sm text-on-surface/70 hover:text-warm transition-colors"
              >
                {label(link.es, link.en)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Conectar -->
      <div class="md:col-span-2 space-y-4">
        <h4 class="font-bitacora italic text-warm text-xs uppercase tracking-[0.2em]">
          {label('// conectar', '// connect')}
        </h4>
        <ul class="space-y-2.5">
          {socialLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="font-body text-sm text-on-surface/70 hover:text-warm transition-colors"
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div class="md:col-span-2 space-y-4">
        <h4 class="font-bitacora italic text-warm text-xs uppercase tracking-[0.2em]">
          {label('// legal', '// legal')}
        </h4>
        <ul class="space-y-2.5">
          {legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-body text-sm text-on-surface/70 hover:text-warm transition-colors"
              >
                {label(link.es, link.en)}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Línea divisoria -->
    <div class="h-px bg-gradient-to-r from-transparent via-on-surface/10 to-transparent mb-8"></div>

    <!-- Bottom: copyright + frase de bitácora -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-xs">
      <div class="font-bitacora text-on-surface/40 tracking-wider">
        © {year} NAUTAS NGO · BUENOS AIRES · ARGENTINA
      </div>
      <div class="font-bitacora italic text-warm tracking-wide">
        // {label('navegamos sin apuro', 'navigating without haste')}
      </div>
    </div>
  </div>
</footer>
