---
export interface GalleryItem {
  type: 'image' | 'card' | 'quote';
  src?: string;
  alt?: string;
  icon?: string;
  title?: string;
  description?: string;
  quote?: string;
  attribution?: string;
  span?: number;
}

export interface Props {
  items: GalleryItem[];
  title?: string;
}

const { items, title } = Astro.props;
---

{title && <h2 class="font-headline text-4xl mb-12 text-center">{title}</h2>}

<div class="grid grid-cols-1 md:grid-cols-4 gap-6">
  {items.map((item) => (
    item.type === 'image' ? (
      <div class={`${item.span ? `md:col-span-${item.span}` : ''} aspect-square md:aspect-video rounded-xl overflow-hidden bg-surface-container-high`}>
        <img
          src={item.src}
          alt={item.alt || ''}
          class="w-full h-full object-cover grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-700"
          loading="lazy"
        />
      </div>
    ) : item.type === 'card' ? (
      <div class="aspect-square rounded-xl overflow-hidden bg-surface-container-high flex flex-col items-center justify-center p-8 text-center border border-outline-variant/10">
        {item.icon && (
          <span class="material-symbols-outlined text-4xl text-primary mb-4">{item.icon}</span>
        )}
        {item.title && <h5 class="font-headline text-lg mb-2">{item.title}</h5>}
        {item.description && <p class="text-xs text-on-surface-variant font-light">{item.description}</p>}
      </div>
    ) : item.type === 'quote' ? (
      <div class={`${item.span ? `md:col-span-${item.span}` : ''} bg-surface-container-low p-12 rounded-xl border border-outline-variant/10 flex items-center`}>
        <blockquote class="font-headline text-xl italic text-on-surface-variant leading-relaxed">
          {item.quote}
          {item.attribution && (
            <footer class="font-label text-xs uppercase tracking-widest text-primary mt-4 not-italic">{item.attribution}</footer>
          )}
        </blockquote>
      </div>
    ) : null
  ))}
</div>
