---
export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  variant?: 'default' | 'split' | 'centered' | 'minimal';
  class?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  image,
  imageAlt = '',
  variant = 'default',
  class: extraClass = '',
} = Astro.props;
---

{
  variant === 'split' ? (
    <section
      class={`relative max-w-[1440px] mx-auto px-6 md:px-12 pt-32 pb-16 md:pb-24 grid md:grid-cols-2 gap-12 md:gap-16 items-center ${extraClass}`}
    >
      {/* Star field (intacto, sigue siendo la firma celestial) */}
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
          {/* Chalk white */}
          <circle class="tw-hi" style="animation-delay:0s; animation-duration:2.8s" cx="5%" cy="8%" r="1.4" fill="#ece8dd" />
          <circle class="tw-mid" style="animation-delay:.7s; animation-duration:3.2s" cx="16%" cy="21%" r="1.0" fill="#ece8dd" />
          <circle class="tw-hi" style="animation-delay:1.4s; animation-duration:2.5s" cx="28%" cy="9%" r="1.9" fill="#ece8dd" />
          <circle class="tw-mid" style="animation-delay:.3s; animation-duration:3.8s" cx="43%" cy="5%" r="1.1" fill="#ece8dd" />
          <circle class="tw-hi" style="animation-delay:2.1s; animation-duration:2.2s" cx="55%" cy="17%" r="2.1" fill="#ece8dd" />
          <circle class="tw-hi" style="animation-delay:.9s; animation-duration:3.0s" cx="71%" cy="6%" r="2.6" fill="#ece8dd" />
          <circle class="tw-mid" style="animation-delay:1.8s; animation-duration:2.6s" cx="85%" cy="23%" r="1.4" fill="#ece8dd" />
          <circle class="tw-hi" style="animation-delay:.5s; animation-duration:3.5s" cx="93%" cy="41%" r="1.9" fill="#ece8dd" />
          <circle class="tw-mid" style="animation-delay:2.8s; animation-duration:4.0s" cx="88%" cy="61%" r="1.2" fill="#ece8dd" />
          <circle class="tw-hi" style="animation-delay:1.2s; animation-duration:2.9s" cx="79%" cy="79%" r="2.1" fill="#ece8dd" />
          <circle class="tw-lo" style="animation-delay:3.5s; animation-duration:3.3s" cx="60%" cy="91%" r="1.5" fill="#ece8dd" />
          <circle class="tw-mid" style="animation-delay:.6s; animation-duration:2.7s" cx="18%" cy="81%" r="1.4" fill="#ece8dd" />
          {/* Pale sky blue */}
          <circle class="tw-mid" style="animation-delay:1.9s; animation-duration:4.2s" cx="31%" cy="93%" r="1.7" fill="#c7e7ff" />
          <circle class="tw-hi" style="animation-delay:2.4s; animation-duration:2.4s" cx="8%" cy="57%" r="1.8" fill="#c7e7ff" />
          <circle class="tw-lo" style="animation-delay:3.0s; animation-duration:3.1s" cx="3%" cy="35%" r="1.2" fill="#c7e7ff" />
          <circle class="tw-lo" style="animation-delay:1.5s; animation-duration:4.5s" cx="38%" cy="47%" r="1.1" fill="#c7e7ff" />
          <circle class="tw-mid" style="animation-delay:2.2s; animation-duration:3.9s" cx="65%" cy="53%" r="1.3" fill="#c7e7ff" />
          <circle class="tw-hi" style="animation-delay:4.0s; animation-duration:2.3s" cx="46%" cy="83%" r="1.6" fill="#c7e7ff" />
          <circle class="tw-mid" style="animation-delay:1.1s; animation-duration:3.6s" cx="51%" cy="31%" r="1.4" fill="#c7e7ff" />
          <circle class="tw-hi" style="animation-delay:3.3s; animation-duration:2.7s" cx="22%" cy="62%" r="3.2" fill="#c7e7ff" />
          {/* Celestial blue */}
          <circle class="tw-mid" style="animation-delay:.8s; animation-duration:3.4s" cx="20%" cy="43%" r="1.6" fill="#a3cce9" />
          <circle class="tw-hi" style="animation-delay:1.7s; animation-duration:2.6s" cx="50%" cy="32%" r="1.4" fill="#a3cce9" />
          <circle class="tw-mid" style="animation-delay:.4s; animation-duration:3.7s" cx="75%" cy="57%" r="1.8" fill="#a3cce9" />
          <circle class="tw-hi" style="animation-delay:2.6s; animation-duration:2.8s" cx="93%" cy="76%" r="1.5" fill="#a3cce9" />
          <circle class="tw-mid" style="animation-delay:3.2s; animation-duration:3.0s" cx="10%" cy="94%" r="1.7" fill="#a3cce9" />
          <circle class="tw-lo" style="animation-delay:1.0s; animation-duration:4.1s" cx="57%" cy="68%" r="1.2" fill="#a3cce9" />
          <circle class="tw-hi" style="animation-delay:3.8s; animation-duration:2.3s" cx="35%" cy="27%" r="1.9" fill="#a3cce9" />
          <circle class="tw-mid" style="animation-delay:2.0s; animation-duration:3.5s" cx="68%" cy="87%" r="1.3" fill="#a3cce9" />
          {/* Medium sky */}
          <circle class="tw-hi" style="animation-delay:.2s; animation-duration:3.6s" cx="44%" cy="15%" r="1.5" fill="#d4ecfa" />
          <circle class="tw-lo" style="animation-delay:2.5s; animation-duration:2.9s" cx="81%" cy="45%" r="1.0" fill="#d4ecfa" />
          <circle class="tw-mid" style="animation-delay:1.3s; animation-duration:4.3s" cx="12%" cy="10%" r="1.7" fill="#d4ecfa" />
          <circle class="tw-hi" style="animation-delay:3.6s; animation-duration:2.5s" cx="62%" cy="73%" r="2.1" fill="#d4ecfa" />
          <circle class="tw-lo" style="animation-delay:.9s; animation-duration:3.8s" cx="27%" cy="48%" r="0.9" fill="#d4ecfa" />
          <circle class="tw-mid" style="animation-delay:4.2s; animation-duration:3.2s" cx="90%" cy="12%" r="1.4" fill="#d4ecfa" />
          <circle class="tw-hi" style="animation-delay:1.6s; animation-duration:2.7s" cx="73%" cy="35%" r="1.2" fill="#d4ecfa" />
          {/* Warm accents (nuevos: brasas dispersas) */}
          <circle class="tw-lo" style="animation-delay:2.3s; animation-duration:4.4s" cx="14%" cy="33%" r="1.3" fill="#d4a574" />
          <circle class="tw-mid" style="animation-delay:.1s; animation-duration:3.9s" cx="82%" cy="67%" r="1.1" fill="#d4a574" />
          <circle class="tw-lo" style="animation-delay:3.7s; animation-duration:3.5s" cx="40%" cy="71%" r="0.9" fill="#d4a574" />
        </svg>
      </div>

      {/* Contenido: lado texto */}
      <div class="relative space-y-7">
        {eyebrow && (
          <span class="font-bitacora italic text-warm text-sm tracking-wide">
            // {eyebrow}
          </span>
        )}

        <h1 class="font-headline text-5xl md:text-7xl lg:text-[5.5rem] xl:text-[6.5rem] leading-[0.95] text-on-surface [&_em]:italic [&_em]:text-warm">
          <Fragment set:html={title} />
        </h1>

        {subtitle && (
          <p class="font-headline italic text-xl md:text-2xl text-on-surface-variant max-w-xl leading-relaxed">
            {subtitle}
          </p>
        )}

        <div class="pt-2">
          <slot />
        </div>
      </div>

      {/* Contenido: lado visual */}
      {image ? (
        <div class="relative">
          <div class="aspect-[4/5] rounded-xl overflow-hidden bg-surface-container-low">
            <img
              src={image}
              alt={imageAlt}
              class="w-full h-full object-cover opacity-80 mix-blend-screen"
              loading="eager"
            />
          </div>
        </div>
      ) : (
        <slot name="visual" />
      )}
    </section>
  ) : variant === 'centered' ? (
    <section
      class={`relative max-w-[1440px] mx-auto px-6 md:px-12 pt-40 pb-20 text-center ${extraClass}`}
    >
      {eyebrow && (
        <span class="font-bitacora italic text-warm text-sm tracking-wide block mb-6">
          // {eyebrow}
        </span>
      )}
      <h1 class="font-headline text-5xl md:text-7xl lg:text-8xl leading-[0.95] mb-8 [&_em]:italic [&_em]:text-warm">
        <Fragment set:html={title} />
      </h1>
      {subtitle && (
        <p class="font-headline italic text-xl md:text-2xl text-on-surface-variant max-w-2xl mx-auto leading-relaxed">
          {subtitle}
        </p>
      )}
      <div class="mt-8">
        <slot />
      </div>
    </section>
  ) : (
    <section
      class={`relative max-w-[1440px] mx-auto px-6 md:px-12 pt-40 pb-20 ${extraClass}`}
    >
      {eyebrow && (
        <span class="font-bitacora italic text-warm text-sm tracking-wide block mb-6">
          // {eyebrow}
        </span>
      )}
      <h1 class="font-headline text-5xl md:text-7xl lg:text-8xl leading-[0.95] mb-8 max-w-4xl [&_em]:italic [&_em]:text-warm">
        <Fragment set:html={title} />
      </h1>
      {subtitle && (
        <p class="font-headline italic text-xl md:text-2xl text-on-surface-variant max-w-3xl leading-relaxed">
          {subtitle}
        </p>
      )}
      <div class="mt-8">
        <slot />
      </div>
    </section>
  )
}

<style>
  @keyframes twinkle-hi  { 0%, 100% { opacity: .90; } 50% { opacity: .07; } }
  @keyframes twinkle-mid { 0%, 100% { opacity: .68; } 50% { opacity: .05; } }
  @keyframes twinkle-lo  { 0%, 100% { opacity: .48; } 50% { opacity: .04; } }

  .tw-hi  { animation: twinkle-hi  3s ease-in-out infinite; }
  .tw-mid { animation: twinkle-mid 3s ease-in-out infinite; }
  .tw-lo  { animation: twinkle-lo  3s ease-in-out infinite; }
</style>
