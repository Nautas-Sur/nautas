---
export interface Props {
  playlistId: string;
  videoId?: string;
  title?: string;
}

const { playlistId, videoId, title = 'YouTube playlist' } = Astro.props;
const origin = Astro.site?.origin ?? '';
const embedSrc = videoId
  ? `https://www.youtube-nocookie.com/embed/${videoId}?origin=${origin}`
  : `https://www.youtube-nocookie.com/embed/videoseries?list=${playlistId}&origin=${origin}`;
---

<div id="yt-player-section" class="relative aspect-video rounded-xl overflow-hidden bg-surface-container-lowest shadow-[0_40px_100px_-20px_rgba(0,0,0,0.6)]" data-playlist-id={playlistId}>
  <iframe
    id="yt-player"
    src={embedSrc}
    title={title}
    class="absolute inset-0 w-full h-full"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
    loading="lazy"
  ></iframe>
</div>
