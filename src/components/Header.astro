---
interface Props {
  currentPath: string;
  locale: string;
  esPath: string;
  enPath: string;
}

const { currentPath, locale, esPath, enPath } = Astro.props;

const navLinks = [
  { es: 'Inicio', en: 'Home', href: '/' },
  { es: 'Institucional', en: 'About', href: '/institucional' },
  { es: 'Proyectos', en: 'Projects', href: '/proyectos' },
  { es: 'Contacto', en: 'Contact', href: '/contacto' },
  { es: 'Archivo', en: 'Archive', href: '/archivo' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/' || currentPath === '/en' || currentPath === '/en/';
  return currentPath.includes(href);
}

const label = (es: string, en: string) => (locale === 'en' ? en : es);
---

<header
  class="fixed top-0 w-full z-50 bg-background/75 backdrop-blur-xl border-b border-warm/[0.06] transition-all duration-500"
  id="header"
>
  <nav class="flex justify-between items-center px-6 md:px-10 py-4 md:py-5 max-w-[1440px] mx-auto">
    <!-- Logo -->
    <a
      href={locale === 'en' ? '/en' : '/'}
      class="shrink-0 transition-opacity hover:opacity-80"
      aria-label="NAUTAS — Inicio"
    >
      <img
        src="/images/nautas-logo.png"
        alt="NAUTAS"
        class="h-9 md:h-11 w-auto"
      />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-2 lg:gap-4">
      {
        navLinks.map((link) => (
          <a
            href={locale === 'en' ? (link.href === '/' ? '/en' : `/en${link.href}`) : link.href}
            class={`relative font-body text-sm tracking-wide transition-all duration-300 px-3 py-2 rounded ${
              isActive(link.href)
                ? 'text-on-surface'
                : 'text-on-surface/60 hover:text-on-surface'
            }`}
          >
            {label(link.es, link.en)}
            {isActive(link.href) && (
              <span class="absolute -bottom-0.5 left-3 right-3 h-px bg-warm" aria-hidden="true"></span>
            )}
          </a>
        ))
      }
    </div>

    <!-- Right side: language + CTA -->
    <div class="flex items-center gap-4 md:gap-5">
      <!-- Language switch (estilo bitácora) -->
      <a
        href={locale === 'es' ? enPath : esPath}
        class="font-bitacora italic text-xs text-warm hover:text-warm-strong transition-colors tracking-wide"
        title={locale === 'es' ? 'English' : 'Español'}
      >
        {locale === 'es' ? '// EN' : '// ES'}
      </a>

      <!-- CTA Button -->
      <a
        href={`${locale === 'en' ? '/en' : ''}/contacto`}
        class="hidden sm:inline-flex items-center gap-1.5 bg-warm text-on-warm px-5 py-2.5 rounded-full font-body text-xs uppercase tracking-[0.12em] font-medium hover:bg-warm-strong hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(212,165,116,0.25)] active:translate-y-0 transition-all duration-300"
      >
        {locale === 'en' ? 'Get on board' : 'A bordo'}
        <span class="text-base" aria-hidden="true">→</span>
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden flex flex-col gap-1.5 p-2"
        aria-label={locale === 'en' ? 'Menu' : 'Menú'}
        aria-expanded="false"
      >
        <span class="block w-5 h-px bg-on-surface transition-all duration-300" id="burger-line-1"></span>
        <span class="block w-5 h-px bg-on-surface transition-all duration-300" id="burger-line-2"></span>
        <span class="block w-5 h-px bg-on-surface transition-all duration-300" id="burger-line-3"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-background/95 backdrop-blur-xl border-t border-warm/[0.08] px-6 py-8"
  >
    <ul class="space-y-5">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={locale === 'en' ? (link.href === '/' ? '/en' : `/en${link.href}`) : link.href}
              class={`flex justify-between items-center font-headline text-2xl tracking-wide transition-colors ${
                isActive(link.href) ? 'text-warm' : 'text-on-surface hover:text-warm'
              }`}
            >
              <span>{label(link.es, link.en)}</span>
              <span class="font-bitacora text-xs text-on-surface/40">→</span>
            </a>
          </li>
        ))
      }
    </ul>

    <!-- CTA mobile -->
    <a
      href={`${locale === 'en' ? '/en' : ''}/contacto`}
      class="mt-8 inline-flex items-center justify-center gap-1.5 w-full bg-warm text-on-warm px-5 py-3 rounded-full font-body text-xs uppercase tracking-[0.12em] font-medium hover:bg-warm-strong transition-all"
    >
      {locale === 'en' ? 'Get on board' : 'A bordo'}
      <span class="text-base" aria-hidden="true">→</span>
    </a>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const line1 = document.getElementById('burger-line-1');
  const line2 = document.getElementById('burger-line-2');
  const line3 = document.getElementById('burger-line-3');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');

      if (isOpen) {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        line1?.classList.remove('translate-y-[6px]', 'rotate-45');
        line2?.classList.remove('opacity-0');
        line3?.classList.remove('-translate-y-[6px]', '-rotate-45');
      } else {
        menu.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        line1?.classList.add('translate-y-[6px]', 'rotate-45');
        line2?.classList.add('opacity-0');
        line3?.classList.add('-translate-y-[6px]', '-rotate-45');
      }
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        line1?.classList.remove('translate-y-[6px]', 'rotate-45');
        line2?.classList.remove('opacity-0');
        line3?.classList.remove('-translate-y-[6px]', '-rotate-45');
      });
    });
  }
</script>
