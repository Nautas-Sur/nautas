---
export interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;

const pillars = [
  { key: 'all', es: 'Todos', en: 'All' },
  { key: 'arte', es: 'Arte', en: 'Art' },
  { key: 'ciencia', es: 'Ciencia', en: 'Science' },
  { key: 'consciencia', es: 'Consciencia', en: 'Consciousness' },
];

const statuses = [
  { key: 'all', es: 'Emitidos y en desarrollo', en: 'Released and in development' },
  { key: 'completed', es: 'Emitido', en: 'Released' },
  { key: 'in_development', es: 'En desarrollo', en: 'In development' },
];

const t = (es: string, en: string) => (locale === 'en' ? en : es);
---

<div id="filter-bar" class="flex flex-wrap gap-2 md:gap-3 items-center mb-12" data-locale={locale}>
  {pillars.map((p, i) => (
    <button
      data-filter="pillar"
      data-key={p.key}
      class={`filter-btn font-bitacora text-xs px-4 py-1.5 rounded-full border transition-all ${
        i === 0
          ? 'border-warm text-warm bg-warm/[0.08]'
          : 'border-on-surface/15 text-on-surface-variant hover:border-warm/40 hover:text-warm'
      }`}
    >
      {t(p.es, p.en)}
    </button>
  ))}

  <span class="w-px h-4 bg-on-surface/15 mx-2 hidden md:block" aria-hidden="true"></span>

  {statuses.map((s, i) => (
    <button
      data-filter="status"
      data-key={s.key}
      class={`filter-btn font-bitacora text-xs px-4 py-1.5 rounded-full border transition-all ${
        i === 0
          ? 'border-warm text-warm bg-warm/[0.08]'
          : 'border-on-surface/15 text-on-surface-variant hover:border-warm/40 hover:text-warm'
      }`}
    >
      {t(s.es, s.en)}
    </button>
  ))}

  <span
    id="filter-count"
    class="ml-auto font-bitacora italic text-warm text-xs"
    data-results-label-es="resultados"
    data-results-label-en="results"
  ></span>
</div>

<script>
  function initFilters() {
    const bar = document.getElementById('filter-bar');
    const cards = document.querySelectorAll<HTMLElement>('[data-pillar][data-status]');
    const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const countEl = document.getElementById('filter-count');

    const locale = bar?.dataset.locale === 'en' ? 'en' : 'es';
    const resultsLabel =
      locale === 'en'
        ? countEl?.dataset.resultsLabelEn || 'results'
        : countEl?.dataset.resultsLabelEs || 'resultados';

    let activePillar = 'all';
    let activeStatus = 'all';

    const ACTIVE_CLASSES = 'border-warm text-warm bg-warm/[0.08]';
    const INACTIVE_CLASSES =
      'border-on-surface/15 text-on-surface-variant hover:border-warm/40 hover:text-warm';
    const BASE_CLASSES =
      'filter-btn font-bitacora text-xs px-4 py-1.5 rounded-full border transition-all';

    function updateBtnStyles() {
      btns.forEach((b) => {
        const filter = b.dataset.filter;
        const key = b.dataset.key;
        const isActive =
          (filter === 'pillar' && key === activePillar) ||
          (filter === 'status' && key === activeStatus);
        b.className = `${BASE_CLASSES} ${isActive ? ACTIVE_CLASSES : INACTIVE_CLASSES}`;
      });
    }

    function filterCards() {
      let visible = 0;
      cards.forEach((card) => {
        const pillar = card.dataset.pillar;
        const status = card.dataset.status;
        const match =
          (activePillar === 'all' || pillar === activePillar) &&
          (activeStatus === 'all' || status === activeStatus);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (countEl) countEl.textContent = `// ${visible} ${resultsLabel}`;
    }

    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        const key = btn.dataset.key!;
        if (filter === 'pillar') activePillar = key;
        if (filter === 'status') activeStatus = key;
        updateBtnStyles();
        filterCards();
      });
    });

    filterCards();
  }

  initFilters();
</script>
