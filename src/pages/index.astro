---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CelestialLine from '../components/CelestialLine.astro';
import GlassPanel from '../components/GlassPanel.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PillarBadge from '../components/PillarBadge.astro';

const locale = Astro.currentLocale || 'es';
const pageSlug = locale === 'en' ? 'en/inicio' : 'inicio';
const page = await getEntry('pages', pageSlug);
const d = page?.data;

const projects = await getCollection('projects');
const completed = projects.filter((p) => p.data.status === 'completed');
const inDev = projects.filter((p) => p.data.status === 'in_development');
const featured = completed.find((p) => p.data.featured);

const pillars = [
  {
    title: d?.pillar_arte_title ?? (locale === 'en' ? 'Art' : 'Arte'),
    desc: d?.pillar_arte_desc ?? '',
    key: 'arte' as const,
  },
  {
    title: d?.pillar_ciencia_title ?? (locale === 'en' ? 'Science' : 'Ciencia'),
    desc: d?.pillar_ciencia_desc ?? '',
    key: 'ciencia' as const,
  },
  {
    title: d?.pillar_consciencia_title ?? (locale === 'en' ? 'Consciousness' : 'Consciencia'),
    desc: d?.pillar_consciencia_desc ?? '',
    key: 'consciencia' as const,
  },
];
---

<BaseLayout
  title={d?.title ?? (locale === 'en' ? 'Home' : 'Inicio')}
  description={d?.description ?? ''}
  locale={locale}
>
  <!-- Hero -->
  <HeroSection
    variant="split"
    eyebrow={d?.hero_eyebrow}
    title={d?.hero_title ?? ''}
    subtitle={d?.hero_subtitle}
  >
    <div class="flex flex-wrap gap-4 pt-4">
      <a
        href={`/${locale === 'en' ? 'en/' : ''}proyectos`}
        class="group inline-flex items-center justify-center gap-2 px-8 py-3 rounded-full bg-warm text-on-warm font-bitacora text-sm hover:-translate-y-0.5 hover:shadow-[0_8px_24px_-8px_rgb(from_var(--color-warm)_r_g_b_/_0.5)] active:scale-95 transition-all"
      >
        {locale === 'en' ? 'View projects' : 'Ver proyectos'}
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
      <a
        href={`/${locale === 'en' ? 'en/' : ''}institucional`}
        class="group inline-flex items-center justify-center gap-2 px-8 py-3 rounded-full border border-warm/40 text-warm font-bitacora text-sm hover:border-warm hover:bg-warm/[0.06] hover:-translate-y-0.5 transition-all"
      >
        {locale === 'en' ? 'About us' : 'Quiénes somos'}
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
    <!-- Sextante / marca de navegación celeste -->
    <div slot="visual" class="hidden md:flex items-center justify-center py-8">
      <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" class="w-56 lg:w-72 xl:w-80" aria-hidden="true">
        <g transform="translate(200 200)" stroke="#a3cce9" fill="none">
          <circle r="180" stroke-width="1.5" opacity="0.12"/>
          <circle r="110" stroke-width="1.5" opacity="0.22"/>
          <circle r="28" fill="#a3cce9" stroke="none" opacity="0.35"/>
          <line x1="0" y1="-220" x2="0" y2="-195" stroke-width="1.5" opacity="0.3"/>
          <line x1="0" y1="195" x2="0" y2="220" stroke-width="1.5" opacity="0.3"/>
          <line x1="-220" y1="0" x2="-195" y2="0" stroke-width="1.5" opacity="0.3"/>
          <line x1="195" y1="0" x2="220" y2="0" stroke-width="1.5" opacity="0.3"/>
        </g>
      </svg>
    </div>
  </HeroSection>

  <CelestialLine />

  <!-- Three Pillars -->
  <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-32">
    <p class="font-bitacora italic text-warm text-sm tracking-widest text-center mb-4">
      // {locale === 'en' ? 'three paths, one horizon' : 'tres caminos, un horizonte'}
    </p>
    <h2
      class="font-headline text-4xl md:text-5xl text-center mb-16 [&_em]:italic [&_em]:text-warm"
      set:html={d?.pillars_title ?? (locale === 'en' ? 'Three Pillars, One Universe' : 'Tres Pilares, Un Universo')}
    />
    <div class="grid md:grid-cols-3 gap-8">
      {pillars.map((p) => {
        const pillarVar = `--color-pillar-${p.key}`;
        const iconWrapStyle = {
          backgroundColor: `rgb(from var(${pillarVar}) r g b / 0.1)`,
          borderColor: `rgb(from var(${pillarVar}) r g b / 0.25)`,
          color: `var(${pillarVar})`,
        };
        return (
          <div class="group p-8 md:p-10 rounded-2xl
                      bg-surface-container-low/40 border border-outline-variant/10
                      hover:border-warm/30 hover:-translate-y-1
                      hover:shadow-[0_20px_60px_-15px_rgb(212_165_116_/_0.15)]
                      transition-all duration-300">
            <div
              class="w-16 h-16 rounded-full border flex items-center justify-center mb-6
                     group-hover:scale-110 transition-transform duration-300"
              style={iconWrapStyle}
            >
              <span class="font-headline text-3xl leading-none" aria-hidden="true">
                {p.key === 'arte' ? '◐' : p.key === 'ciencia' ? '✧' : '❍'}
              </span>
            </div>
            <p class="font-bitacora text-xs uppercase tracking-widest text-warm/70 mb-2">
              // {p.key === 'arte' ? '01' : p.key === 'ciencia' ? '02' : '03'}
            </p>
            <h3 class="font-headline text-2xl mb-4 group-hover:text-warm transition-colors">{p.title}</h3>
            <p class="text-on-surface-variant leading-relaxed">{p.desc}</p>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Featured Production -->
  {featured && (
    <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-32">
      <p class="font-bitacora italic text-warm text-sm mb-6">
        // {locale === 'en' ? 'featured' : 'destacado'}
      </p>
      <h2 class="font-headline text-4xl md:text-5xl mb-12 [&_em]:italic [&_em]:text-warm"
        set:html={locale === 'en' ? 'Featured <em>Production</em>' : 'Producción <em>Destacada</em>'}
      />
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="aspect-video rounded-xl overflow-hidden bg-surface-container-lowest relative">
          {featured.data.playlistId ? (
            <iframe
              src={featured.data.featuredVideoId
                ? `https://www.youtube-nocookie.com/embed/${featured.data.featuredVideoId}?origin=https://project-43ure.vercel.app`
                : `https://www.youtube-nocookie.com/embed/videoseries?list=${featured.data.playlistId}&origin=https://project-43ure.vercel.app`
              }
              title={featured.data.title}
              class="absolute inset-0 w-full h-full"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          ) : (
            <div class="w-full h-full flex items-center justify-center">
              <span class="font-headline text-warm/20 text-8xl leading-none" aria-hidden="true">▷</span>
            </div>
          )}
        </div>
        <div class="space-y-6">
          <div class="flex items-center gap-3">
            <PillarBadge pillar={featured.data.pillar} locale={locale} />
            <span class="font-bitacora italic text-warm/70 text-xs">// {featured.data.kind}</span>
          </div>
          <h3 class="font-headline text-4xl md:text-5xl">{featured.data.title}</h3>
          <p class="text-lg text-on-surface-variant leading-relaxed">{locale === 'en' ? featured.data.tagline.en : featured.data.tagline.es}</p>
          <p class="text-on-surface-variant/70 leading-relaxed line-clamp-3">{locale === 'en' ? featured.data.description.en : featured.data.description.es}</p>
          <a
            href={`/${locale === 'en' ? 'en/' : ''}proyectos/${featured.id}`}
            class="group inline-flex items-center gap-2 text-warm font-bitacora text-sm hover:gap-3 transition-all"
          >
            {locale === 'en' ? 'View project' : 'Ver proyecto'}
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Completed Productions Grid -->
  {completed.length > 0 && (
    <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-32">
      <p class="font-bitacora italic text-warm text-sm mb-6">
        // {locale === 'en' ? 'archive' : 'archivo'}
      </p>
      <h2 class="font-headline text-4xl md:text-5xl mb-12">{locale === 'en' ? 'Productions' : 'Producciones'}</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {completed.map((p) => (
          <ProjectCard
            title={p.data.title}
            slug={p.id}
            kind={p.data.kind}
            pillar={p.data.pillar}
            tagline={locale === 'en' ? p.data.tagline.en : p.data.tagline.es}
            year={p.data.year}
            episodeCount={p.data.episodes?.length}
            image={p.data.heroImage}
            status="completed"
            locale={locale}
          />
        ))}
      </div>
    </section>
  )}

  <!-- In Development -->
  {inDev.length > 0 && (
    <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-32">
      <p class="font-bitacora italic text-warm text-sm mb-6">
        // {locale === 'en' ? 'on the horizon' : 'en el horizonte'}
      </p>
      <h2 class="font-headline text-4xl md:text-5xl mb-12">{locale === 'en' ? 'In Development' : 'En Desarrollo'}</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {inDev.map((p) => (
          <ProjectCard
            title={p.data.title}
            slug={p.id}
            kind={p.data.kind}
            pillar={p.data.pillar}
            tagline={locale === 'en' ? p.data.tagline.en : p.data.tagline.es}
            status="in_development"
            locale={locale}
            variant="horizontal"
          />
        ))}
      </div>
    </section>
  )}

  <!-- Vision Quote -->
  <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-20">
    <GlassPanel padding="xl">
      <div class="text-center max-w-3xl mx-auto">
        <p class="font-bitacora italic text-warm text-sm tracking-widest mb-8">
          // {locale === 'en' ? 'vision' : 'visión'}
        </p>
        <span class="font-headline text-warm/40 text-7xl md:text-8xl leading-none block mb-2 select-none" aria-hidden="true">
          "
        </span>
        <blockquote class="font-headline text-2xl md:text-3xl italic text-on-surface leading-relaxed mb-10">
          {d?.vision_quote ?? ''}
        </blockquote>
        <div class="flex items-center justify-center gap-4">
          <span class="h-px w-12 bg-warm/30"></span>
          <span class="font-bitacora italic text-warm/70 text-xs tracking-widest">
            // nautas
          </span>
          <span class="h-px w-12 bg-warm/30"></span>
        </div>
      </div>
    </GlassPanel>
  </section>

  <!-- Newsletter CTA -->
  <section class="max-w-[1200px] mx-auto px-6 md:px-12 mb-20 text-center
                  py-24 md:py-32 bg-nebula rounded-3xl relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.06] pointer-events-none">
      <svg viewBox="0 0 100 100" class="w-full h-full">
        <circle cx="50" cy="50" fill="none" r="40" stroke="currentColor" class="text-warm"></circle>
        <circle cx="50" cy="50" fill="none" r="20" stroke="currentColor" class="text-warm"></circle>
      </svg>
    </div>

    <div class="relative z-10">
      <p class="font-bitacora italic text-warm text-sm tracking-widest mb-4">
        // {locale === 'en' ? 'logbook' : 'bitácora'}
      </p>

      <h2 class="font-headline text-4xl md:text-5xl mb-6">
        {d?.newsletter_title ?? ''}
      </h2>

      <p class="text-on-surface-variant text-lg md:text-xl max-w-2xl mx-auto mb-12">
        {d?.newsletter_subtitle ?? ''}
      </p>

      <form class="flex flex-col sm:flex-row justify-center gap-3 max-w-md mx-auto group/form">
        <div class="relative flex-grow">
          <span class="absolute left-0 top-1/2 -translate-y-1/2
                       font-bitacora italic text-warm/0 group-focus-within/form:text-warm/70
                       text-sm transition-all duration-300
                       pointer-events-none"
                aria-hidden="true">
            //
          </span>
          <input
            class="bg-transparent border-b border-outline-variant/30
                   focus:border-warm focus:ring-0
                   text-on-surface py-3 px-4
                   focus:pl-8
                   outline-none transition-all duration-300 w-full
                   placeholder:text-on-surface/30 placeholder:italic"
            placeholder={locale === 'en' ? 'stellar@navigator.com' : 'estelar@navegante.com'}
            type="email"
            required
          />
        </div>
        <button type="submit"
                class="group/btn bg-warm text-on-warm px-8 py-3 rounded-full
                       font-bitacora text-xs uppercase tracking-[0.2em]
                       whitespace-nowrap inline-flex items-center justify-center gap-2
                       hover:-translate-y-0.5
                       hover:shadow-[0_10px_30px_-10px_rgb(212_165_116_/_0.4)]
                       transition-all duration-300">
          <span>{locale === 'en' ? 'embark' : 'embarcate'}</span>
          <span class="transition-transform duration-300 group-hover/btn:translate-x-1">→</span>
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
