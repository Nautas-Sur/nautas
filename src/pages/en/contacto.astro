---
import { getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import CelestialLine from '../../components/CelestialLine.astro';

const locale = Astro.currentLocale || 'es';
const pageSlug = locale === 'en' ? 'en/contacto' : 'contacto';
const page = await getEntry('pages', pageSlug);
const d = page?.data;
---

<BaseLayout
  title={d?.title ?? ''}
  description={d?.description ?? ''}
  locale={locale}
>
  <section class="max-w-[1440px] mx-auto px-6 md:px-12 pt-32 pb-16">
    <div class="grid md:grid-cols-2 gap-16">
      {/* Left: Info */}
      <div>
        <p class="font-bitacora italic text-warm text-sm mb-6">
          // {locale === 'en' ? 'write to us' : 'escribínos'}
        </p>
        <h1 class="font-headline text-5xl md:text-7xl leading-tight mb-4">
          {d?.hero_title ?? ''}
        </h1>
        <p class="font-headline italic text-xl text-on-surface-variant mb-12">
          {d?.contact_tagline ?? ''}
        </p>

        <div class="space-y-8">
          <div>
            <span class="font-bitacora italic text-warm text-xs block mb-2">
              // {d?.email_label ?? 'email'}
            </span>
            <a href={`mailto:${d?.email ?? 'contacto@nautas.org'}`} class="text-xl text-on-surface hover:text-warm transition-colors">
              {d?.email ?? 'contacto@nautas.org'}
            </a>
          </div>

          <div>
            <span class="font-bitacora italic text-warm text-xs block mb-2">
              // {d?.youtube_label ?? 'youtube'}
            </span>
            <a href={d?.youtube_url ?? 'https://www.youtube.com/@Nautas'} target="_blank" rel="noopener noreferrer" class="text-xl text-on-surface hover:text-warm transition-colors">
              {d?.youtube_display ?? 'youtube.com/@Nautas'}
            </a>
          </div>

          <div>
            <span class="font-bitacora italic text-warm text-xs block mb-2">
              // {d?.location_label ?? (locale === 'en' ? 'location' : 'ubicación')}
            </span>
            <p class="text-xl text-on-surface">
              {d?.location ?? 'Buenos Aires, Argentina'}
            </p>
          </div>

          <div>
            <span class="font-bitacora italic text-warm text-xs block mb-2">
              // {d?.response_label ?? (locale === 'en' ? 'response time' : 'tiempo de respuesta')}
            </span>
            <p class="text-on-surface-variant">
              {d?.response_time ?? (locale === 'en' ? '3-5 business days' : '3 a 5 días hábiles')}
            </p>
          </div>
        </div>

        <CelestialLine />

        {/* Social */}
        <div class="flex gap-4">
          <a
            href="https://www.instagram.com/nautas_sur/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="w-12 h-12 inline-flex items-center justify-center rounded-full border border-on-surface/15 text-on-surface-variant hover:border-warm hover:text-warm hover:-translate-y-0.5 transition-all"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="4" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" />
            </svg>
          </a>
          <a
            href="https://web.facebook.com/nautas.org"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="w-12 h-12 inline-flex items-center justify-center rounded-full border border-on-surface/15 text-on-surface-variant hover:border-warm hover:text-warm hover:-translate-y-0.5 transition-all"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5" aria-hidden="true">
              <path d="M 14 8 L 14 6 Q 14 4 16 4 L 18 4 M 14 8 L 14 20 M 10 12 L 18 12" stroke-linecap="round" />
            </svg>
          </a>
          <a
            href="https://www.youtube.com/@Nautas"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="YouTube"
            class="w-12 h-12 inline-flex items-center justify-center rounded-full border border-on-surface/15 text-on-surface-variant hover:border-warm hover:text-warm hover:-translate-y-0.5 transition-all"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5" aria-hidden="true">
              <rect x="2" y="6" width="20" height="12" rx="2" />
              <polygon points="10,9 16,12 10,15" fill="currentColor" />
            </svg>
          </a>
          <a
            href="https://linktr.ee/nautas"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Linktree"
            class="w-12 h-12 inline-flex items-center justify-center rounded-full border border-on-surface/15 text-on-surface-variant hover:border-warm hover:text-warm hover:-translate-y-0.5 transition-all"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
              <path d="M11.39 21.5h2.61V13.5l5.66 5.66 1.84-1.84L15.84 11.66H22V9.05h-6.16l5.66-5.66L19.66 1.55 14 7.21V1.5h-2.61V7.2L5.73 1.55 3.89 3.39 9.55 9.05H3.39v2.61h6.16L3.89 17.32l1.84 1.84 5.66-5.66z"/>
            </svg>
          </a>
        </div>
      </div>

      {/* Right: Form */}
      <div class="glass-panel rounded-2xl p-8 md:p-12">
        <h2 class="font-headline text-2xl mb-8">
          {d?.form_title ?? (locale === 'en' ? 'Send your message' : 'Enviá tu mensaje')}
        </h2>
        <ContactForm locale={locale} />
      </div>
    </div>
  </section>
</BaseLayout>
