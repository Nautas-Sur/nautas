---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import CelestialLine from '../../components/CelestialLine.astro';

const locale = Astro.currentLocale || 'es';
const t = (es: string, en: string) => (locale === 'en' ? en : es);
---

<BaseLayout
  title={t('Contacto', 'Contact')}
  description={t(
    'Contactá a NAUTAS. Escribinos para consultas, colaboraciones, prensa o sumarte al equipo.',
    'Contact NAUTAS. Write to us for inquiries, collaborations, press, or joining the team.'
  )}
  locale={locale}
>
  <section class="max-w-[1440px] mx-auto px-6 md:px-12 pt-32 pb-16">
    <div class="grid md:grid-cols-2 gap-16">
      <!-- Left: Info -->
      <div>
        <h1 class="font-headline text-5xl md:text-7xl leading-tight mb-4">
          {t('Escribinos.', 'Write to Us.')}
        </h1>
        <p class="font-headline italic text-xl text-on-surface-variant mb-12">
          {t('Cada nave necesita tripulación.', 'Every vessel needs a crew.')}
        </p>

        <div class="space-y-8">
          <div>
            <span class="font-label text-xs uppercase tracking-widest text-tertiary block mb-1">
              {t('Correo Electrónico', 'Email')}
            </span>
            <a href="mailto:contacto@nautas.org" class="text-xl text-on-surface hover:text-primary transition-colors">
              contacto@nautas.org
            </a>
          </div>

          <div>
            <span class="font-label text-xs uppercase tracking-widest text-tertiary block mb-1">
              {t('YouTube', 'YouTube')}
            </span>
            <a href="https://youtube.com/@Nautas" target="_blank" rel="noopener noreferrer" class="text-xl text-on-surface hover:text-primary transition-colors">
              youtube.com/@Nautas
            </a>
          </div>

          <div>
            <span class="font-label text-xs uppercase tracking-widest text-tertiary block mb-1">
              {t('Ubicación', 'Location')}
            </span>
            <p class="text-xl text-on-surface">
              {t('Buenos Aires, Argentina', 'Buenos Aires, Argentina')}
            </p>
          </div>

          <div>
            <span class="font-label text-xs uppercase tracking-widest text-tertiary block mb-1">
              {t('Tiempo de Respuesta', 'Response Time')}
            </span>
            <p class="text-on-surface-variant">
              {t('3 a 5 días hábiles', '3-5 business days')}
            </p>
          </div>
        </div>

        <CelestialLine />

        <!-- Social -->
        <div class="flex gap-6">
          <a href="https://instagram.com/nautas" target="_blank" rel="noopener noreferrer" class="text-on-surface-variant hover:text-primary transition-colors" aria-label="Instagram">
            <span class="material-symbols-outlined text-3xl">photo_camera</span>
          </a>
          <a href="https://facebook.com/nautas" target="_blank" rel="noopener noreferrer" class="text-on-surface-variant hover:text-primary transition-colors" aria-label="Facebook">
            <span class="material-symbols-outlined text-3xl">groups</span>
          </a>
          <a href="https://youtube.com/@Nautas" target="_blank" rel="noopener noreferrer" class="text-on-surface-variant hover:text-primary transition-colors" aria-label="YouTube">
            <span class="material-symbols-outlined text-3xl">play_circle</span>
          </a>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="glass-panel rounded-2xl p-8 md:p-12">
        <h2 class="font-headline text-2xl mb-8">
          {t('Enviá tu mensaje', 'Send your message')}
        </h2>
        <ContactForm locale={locale} />
      </div>
    </div>
  </section>
</BaseLayout>
