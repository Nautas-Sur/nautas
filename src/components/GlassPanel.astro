---
export interface Props {
  padding?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
}

const { padding = 'lg', class: extraClass = '' } = Astro.props;
const pad = { sm: 'p-4', md: 'p-6', lg: 'p-8 md:p-12', xl: 'p-12 md:p-20' }[padding];
---

<div class={`glass-panel rounded-2xl ${pad} ${extraClass}`}>
  <slot />
</div>
