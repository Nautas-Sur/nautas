---
export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  variant?: 'default' | 'split' | 'centered' | 'minimal';
  class?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  image,
  imageAlt = '',
  variant = 'default',
  class: extraClass = '',
} = Astro.props;
---

{
  variant === 'split' ? (
    <section class={`relative max-w-[1440px] mx-auto px-6 md:px-12 pt-32 pb-16 md:pb-24 grid md:grid-cols-2 gap-12 md:gap-16 items-center ${extraClass}`}>
      <!-- Star field -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
          <circle cx="8%" cy="15%" r="1.4" fill="#e1e1f0" opacity="0.6"/>
          <circle cx="22%" cy="28%" r="1" fill="#e1e1f0" opacity="0.45"/>
          <circle cx="78%" cy="12%" r="1.8" fill="#e1e1f0" opacity="0.7"/>
          <circle cx="91%" cy="35%" r="1.2" fill="#e1e1f0" opacity="0.55"/>
          <circle cx="65%" cy="82%" r="1.3" fill="#e1e1f0" opacity="0.6"/>
          <circle cx="12%" cy="72%" r="1.5" fill="#e1e1f0" opacity="0.55"/>
          <circle cx="85%" cy="65%" r="1" fill="#e1e1f0" opacity="0.4"/>
          <circle cx="45%" cy="92%" r="1.1" fill="#e1e1f0" opacity="0.45"/>
          <circle cx="95%" cy="85%" r="0.9" fill="#e1e1f0" opacity="0.45"/>
          <circle cx="35%" cy="5%" r="1.3" fill="#e1e1f0" opacity="0.55"/>
        </svg>
      </div>
      <div class="space-y-6">
        {eyebrow && (
          <span class="font-label text-xs tracking-[0.3em] text-tertiary uppercase">{eyebrow}</span>
        )}
        <h1 class="font-headline text-5xl md:text-7xl lg:text-8xl leading-tight text-on-surface [&_em]:italic [&_em]:text-primary">
          {title}
        </h1>
        {subtitle && (
          <p class="font-body text-lg text-on-surface-variant max-w-lg leading-relaxed">{subtitle}</p>
        )}
        <slot />
      </div>
      {image ? (
        <div class="relative">
          <div class="aspect-[4/5] rounded-xl overflow-hidden bg-surface-container-low">
            <img
              src={image}
              alt={imageAlt}
              class="w-full h-full object-cover opacity-80 mix-blend-screen"
              loading="eager"
            />
          </div>
        </div>
      ) : (
        <slot name="visual" />
      )}
    </section>
  ) : variant === 'centered' ? (
    <section class={`max-w-[1440px] mx-auto px-6 md:px-12 pt-40 pb-20 text-center ${extraClass}`}>
      {eyebrow && (
        <span class="font-label text-xs tracking-[0.3em] text-tertiary uppercase block mb-6">{eyebrow}</span>
      )}
      <h1 class="font-headline text-5xl md:text-7xl lg:text-8xl leading-tight mb-8">{title}</h1>
      {subtitle && (
        <p class="font-body text-xl text-on-surface-variant max-w-2xl mx-auto leading-relaxed">{subtitle}</p>
      )}
      <slot />
    </section>
  ) : (
    <section class={`max-w-[1440px] mx-auto px-6 md:px-12 pt-40 pb-20 ${extraClass}`}>
      {eyebrow && (
        <span class="font-label text-xs tracking-[0.3em] text-tertiary uppercase block mb-6">{eyebrow}</span>
      )}
      <h1 class="font-headline text-5xl md:text-7xl lg:text-8xl leading-tight mb-8 max-w-4xl">{title}</h1>
      {subtitle && (
        <p class="font-body text-xl text-on-surface-variant max-w-3xl leading-relaxed">{subtitle}</p>
      )}
      <slot />
    </section>
  )
}
