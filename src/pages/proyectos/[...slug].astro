---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import CelestialLine from '../../components/CelestialLine.astro';
import GlassPanel from '../../components/GlassPanel.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import EpisodeList from '../../components/EpisodeList.astro';
import PillarBadge from '../../components/PillarBadge.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const projects = await getCollection('projects');
  return projects.map((p) => ({
    params: { slug: p.id },
  }));
};

const { slug } = Astro.params;
const locale = Astro.currentLocale || 'es';
const t = (es: string, en: string) => (locale === 'en' ? en : es);

const projects = await getCollection('projects');
const project = projects.find((p) => p.id === slug);

if (!project) {
  return Astro.rewrite('/404');
}

const { data } = project;
const description = t(data.description.es, data.description.en);
const tagline = t(data.tagline.es, data.tagline.en);

// Related: other projects of same pillar
const related = projects
  .filter((p) => p.id !== slug)
  .filter((p) => p.data.pillar === data.pillar)
  .slice(0, 3);
---

<BaseLayout
  title={data.title}
  description={description.slice(0, 160)}
  locale={locale}
>
  <!-- Hero -->
  <section class="max-w-[1440px] mx-auto px-6 md:px-12 pt-32 pb-16">
    <a
      href={`/${locale === 'en' ? 'en/' : ''}proyectos`}
      class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm mb-8 transition-colors"
    >
      <span class="material-symbols-outlined text-sm">arrow_back</span>
      {t('Volver a Proyectos', 'Back to Projects')}
    </a>

    <div class="flex flex-wrap items-center gap-3 mb-6">
      <PillarBadge pillar={data.pillar} locale={locale} />
      <span class="font-label text-xs uppercase tracking-widest text-on-surface-variant">{data.kind}</span>
      {data.status === 'completed' ? (
        <span class="font-label text-[10px] text-primary tracking-widest uppercase bg-primary-container/50 px-2 py-0.5 rounded-full">
          {t('Expedición Activa', 'Active Expedition')}
        </span>
      ) : (
        <span class="font-label text-[10px] text-tertiary tracking-widest uppercase bg-tertiary-container/50 px-2 py-0.5 rounded-full">
          {t('En Desarrollo', 'In Development')}
        </span>
      )}
      {data.year && <span class="font-label text-xs text-on-surface-variant ml-auto">{data.year}</span>}
    </div>

    <h1 class="font-headline text-5xl md:text-7xl lg:text-8xl leading-tight mb-6">
      {data.title}
    </h1>
    <p class="font-headline italic text-xl md:text-2xl text-on-surface-variant max-w-3xl leading-relaxed">
      {tagline}
    </p>
  </section>

  <!-- YouTube Embed (for completed productions) -->
  {data.playlistId && (
    <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-16">
      <YouTubeEmbed playlistId={data.playlistId} videoId={data.featuredVideoId} title={data.title} />
    </section>
  )}

  <!-- Main Content Grid -->
  <div class="max-w-[1440px] mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      <!-- Main -->
      <div class="lg:col-span-8 space-y-12">
        {/* Description */}
        <section class="space-y-6">
          {description.split('\n\n').filter(Boolean).map((p, i) =>
            i === 0 ? (
              <p class="text-xl text-on-surface font-headline italic leading-relaxed border-l-2 border-primary/40 pl-6">
                {p.trim()}
              </p>
            ) : (
              <p class="text-on-surface-variant leading-relaxed text-lg">{p.trim()}</p>
            )
          )}
        </section>

        {/* Feature Cards */}
        {data.featureCards && data.featureCards.length > 0 && (
          <section class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-8 border-t border-outline-variant/10">
            {data.featureCards.map((card) => (
              <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/10">
                <span class="material-symbols-outlined text-3xl text-primary mb-4 block">{card.icon}</span>
                <h4 class="font-headline text-lg mb-3">{t(card.title.es, card.title.en)}</h4>
                <p class="text-sm text-on-surface-variant leading-relaxed">{t(card.description.es, card.description.en)}</p>
              </div>
            ))}
          </section>
        )}

        {/* Voices */}
        {data.voices && data.voices.length > 0 && (
          <section class="pt-8 border-t border-outline-variant/10">
            <h3 class="font-headline text-2xl mb-6">{t('Voces Destacadas', 'Featured Voices')}</h3>
            <div class="flex flex-wrap gap-2">
              {data.voices.map((voice) => (
                <span class="inline-block px-4 py-1.5 rounded text-xs font-label tracking-widest bg-surface-container text-on-surface-variant border border-outline-variant/15">
                  {voice}
                </span>
              ))}
            </div>
          </section>
        )}

        {/* Phases (in development) */}
        {data.phases && data.phases.length > 0 && (
          <section class="pt-8 border-t border-outline-variant/10">
            <h3 class="font-headline text-2xl mb-8">{t('Fases del Programa', 'Program Phases')}</h3>
            <div class="grid sm:grid-cols-2 gap-6">
              {data.phases.map((phase) => (
                <div class="flex gap-4 p-6 bg-surface-container-low rounded-xl border border-outline-variant/10">
                  <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center shrink-0">
                    <span class="font-headline text-primary text-lg">{phase.letter}</span>
                  </div>
                  <div>
                    <h4 class="font-headline text-base mb-2">{t(phase.title.es, phase.title.en)}</h4>
                    <p class="text-sm text-on-surface-variant leading-relaxed">{t(phase.description.es, phase.description.en)}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}
      </div>

      {/* Sidebar */}
      <aside class="lg:col-span-4 space-y-8 lg:sticky lg:top-32">
        {/* Episodes */}
        {data.episodes && data.episodes.length > 0 && (
          <EpisodeList
            episodes={data.episodes.map((ep, i) => ({
              number: ep.number,
              title: t(ep.title.es, ep.title.en),
              description: ep.description ? t(ep.description.es, ep.description.en) : undefined,
              videoId: ep.videoId,
              active: !data.featuredVideoId && i === 0,
            }))}
            trailer={data.featuredVideoId ? {
              videoId: data.featuredVideoId,
              active: true,
              title: t('Adelanto de la serie', 'Series trailer'),
              label: t('adelanto', 'trailer'),
            } : undefined}
            playlistId={data.playlistId}
            title={t('Episodios', 'Episodes')}
            countLabel={`${data.episodes.length} ${t('VIDEOS', 'VIDEOS')}`}
            locale={locale}
          />
        )}

        {/* CTA Box */}
        {data.ctaText && (
          <GlassPanel padding="md">
            <div class="text-center">
              <h4 class="font-headline text-xl text-primary mb-4 italic">
                {t('Explorá la Serie', 'Explore the Series')}
              </h4>
              <p class="text-xs text-on-surface-variant leading-relaxed mb-6">
                {t(
                  'Contenidos holísticos y sensitivos en armonía con el planeta.',
                  'Holistic and sensitive content in harmony with the planet.'
                )}
              </p>
              {data.ctaLink && (
                <a
                  href={data.ctaLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block w-full py-3 bg-primary text-on-primary text-xs uppercase tracking-widest font-label rounded hover:brightness-110 transition-all text-center"
                >
                  {t(data.ctaText.es, data.ctaText.en)}
                </a>
              )}
            </div>
          </GlassPanel>
        )}
      </aside>
    </div>

    {/* Related Projects */}
    {related.length > 0 && (
      <section class="mt-32 mb-20">
        <CelestialLine />
        <h2 class="font-headline text-3xl md:text-4xl mb-10">
          {t('Producciones Relacionadas', 'Related Productions')}
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {related.map((p) => (
            <a
              href={`/${locale === 'en' ? 'en/' : ''}proyectos/${p.id}`}
              class="group p-6 bg-surface-container-low rounded-xl border border-outline-variant/10 hover:bg-surface-container-high transition-all"
            >
              <div class="flex items-center gap-2 mb-3">
                <PillarBadge pillar={p.data.pillar} locale={locale} />
              </div>
              <h3 class="font-headline text-xl group-hover:text-primary transition-colors">{p.data.title}</h3>
              <p class="text-sm text-on-surface-variant mt-2 line-clamp-2">{t(p.data.tagline.es, p.data.tagline.en)}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
