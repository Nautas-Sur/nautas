---
interface Props {
  currentPath: string;
  locale: string;
  esPath: string;
  enPath: string;
}

const { currentPath, locale, esPath, enPath } = Astro.props;

const navLinks = [
  { es: 'Inicio', en: 'Home', href: '/' },
  { es: 'Institucional', en: 'About', href: '/institucional' },
  { es: 'Proyectos', en: 'Projects', href: '/proyectos' },
  { es: 'Contacto', en: 'Contact', href: '/contacto' },
  { es: 'Archivo', en: 'Archive', href: '/archivo' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/' || currentPath === '/en' || currentPath === '/en/';
  return currentPath.includes(href);
}

const label = (es: string, en: string) => (locale === 'en' ? en : es);
---

<header class="fixed top-0 w-full z-50 bg-[#11131d]/60 backdrop-blur-xl transition-all duration-500" id="header">
  <nav class="flex justify-between items-center px-6 md:px-12 py-5 max-w-[1440px] mx-auto">
    <!-- Logo -->
    <a href={locale === 'en' ? '/en' : '/'} class="text-xl md:text-2xl font-headline italic text-primary tracking-wide shrink-0">
      NAUTAS
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-6 lg:gap-10">
      {
        navLinks.map((link) => (
          <a
            href={`${locale === 'en' ? '/en' : ''}${link.href === '/' ? '' : link.href}`}
            class={`font-headline text-base lg:text-lg tracking-wide transition-all duration-300 hover:text-primary hover:bg-white/5 rounded px-2 py-1 ${
              isActive(link.href)
                ? 'text-primary border-b border-primary/30 pb-1'
                : 'text-on-surface/70'
            }`}
          >
            {label(link.es, link.en)}
          </a>
        ))
      }
    </div>

    <!-- Right side: language + CTA -->
    <div class="flex items-center gap-3 md:gap-5">
      <!-- Language switch -->
      <a
        href={locale === 'es' ? enPath : esPath}
        class="font-label text-xs uppercase tracking-widest text-on-surface/60 hover:text-primary transition-colors"
        title={locale === 'es' ? 'English' : 'Español'}
      >
        {locale === 'es' ? 'EN' : 'ES'}
      </a>

      <!-- CTA Button -->
      <a
        href={`${locale === 'en' ? '/en' : ''}/contacto`}
        class="hidden sm:inline-block bg-primary text-on-primary px-5 py-2 rounded font-label text-xs uppercase tracking-widest hover:brightness-110 active:scale-95 transition-all duration-200"
      >
        {locale === 'en' ? 'Join the Mission' : 'Únete a la Misión'}
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-on-surface p-1"
        aria-label={locale === 'en' ? 'Menu' : 'Menú'}
      >
        <span class="material-symbols-outlined text-2xl">menu</span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-surface-container-low border-t border-outline-variant/10 px-6 py-6 space-y-4">
    {
      navLinks.map((link) => (
        <a
          href={`${locale === 'en' ? '/en' : ''}${link.href === '/' ? '' : link.href}`}
          class={`block font-headline text-lg tracking-wide transition-colors ${
            isActive(link.href) ? 'text-primary' : 'text-on-surface/70'
          }`}
        >
          {label(link.es, link.en)}
        </a>
      ))
    }
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
