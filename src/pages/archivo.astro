---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ProjectCard from '../components/ProjectCard.astro';
import FilterBar from '../components/FilterBar.astro';

const locale = Astro.currentLocale || 'es';
const pageSlug = locale === 'en' ? 'en/archivo' : 'archivo';
const page = await getEntry('pages', pageSlug);
const d = page?.data;

const projects = await getCollection('projects');
---

<BaseLayout
  title={d?.title ?? ''}
  description={d?.description ?? ''}
  locale={locale}
>
  <HeroSection
    variant="default"
    title={d?.hero_title ?? ''}
    subtitle={d?.hero_subtitle}
  />

  <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-20">
    <FilterBar locale={locale} />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {projects.map((p) => (
        <div data-pillar={p.data.pillar} data-status={p.data.status}>
          <ProjectCard
            title={p.data.title}
            slug={p.id}
            kind={p.data.kind}
            pillar={p.data.pillar}
            tagline={locale === 'en' ? p.data.tagline.en : p.data.tagline.es}
            year={p.data.year}
            episodeCount={p.data.episodes?.length}
            image={p.data.heroImage}
            status={p.data.status}
            locale={locale}
          />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
