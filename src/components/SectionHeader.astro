---
export interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { title, subtitle, align = 'left', class: extraClass = '' } = Astro.props;
---

<div class={`mb-12 md:mb-16 ${align === 'center' ? 'text-center' : ''} ${extraClass}`}>
  <h2 class="font-headline text-4xl md:text-5xl mb-4">{title}</h2>
  {subtitle && (
    <p class="text-on-surface-variant text-lg max-w-2xl leading-relaxed">{subtitle}</p>
  )}
</div>
