---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import CelestialLine from '../../components/CelestialLine.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const locale = Astro.currentLocale || 'es';
const pageSlug = locale === 'en' ? 'en/proyectos' : 'proyectos';
const page = await getEntry('pages', pageSlug);
const d = page?.data;

const projects = await getCollection('projects');
const completed = projects.filter((p) => p.data.status === 'completed');
const inDev = projects.filter((p) => p.data.status === 'in_development');
---

<BaseLayout
  title={d?.title ?? ''}
  description={d?.description ?? ''}
  locale={locale}
>
  <HeroSection
    variant="default"
    eyebrow={d?.hero_eyebrow}
    title={d?.hero_title ?? ''}
    subtitle={d?.hero_subtitle}
  />

  <CelestialLine />

  <!-- Completed -->
  {completed.length > 0 && (
    <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-32">
      <h2 class="font-headline text-4xl md:text-5xl mb-12">{d?.completed_title ?? (locale === 'en' ? 'Productions' : 'Producciones')}</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {completed.map((p) => (
          <ProjectCard
            title={p.data.title}
            slug={p.id}
            kind={p.data.kind}
            pillar={p.data.pillar}
            tagline={locale === 'en' ? p.data.tagline.en : p.data.tagline.es}
            year={p.data.year}
            episodeCount={p.data.episodes?.length}
            image={p.data.heroImage}
            status="completed"
            locale={locale}
          />
        ))}
      </div>
    </section>
  )}

  <CelestialLine />

  <!-- In Development -->
  {inDev.length > 0 && (
    <section class="max-w-[1440px] mx-auto px-6 md:px-12 mb-20">
      <h2 class="font-headline text-4xl md:text-5xl mb-12">{d?.in_dev_title ?? (locale === 'en' ? 'In Development' : 'En Desarrollo')}</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {inDev.map((p) => (
          <ProjectCard
            title={p.data.title}
            slug={p.id}
            kind={p.data.kind}
            pillar={p.data.pillar}
            tagline={locale === 'en' ? p.data.tagline.en : p.data.tagline.es}
            status="in_development"
            locale={locale}
            variant="horizontal"
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
