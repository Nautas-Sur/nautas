---
export interface Props {
  pillar: 'arte' | 'ciencia' | 'consciencia';
  locale?: string;
}

const { pillar, locale = 'es' } = Astro.props;

const icons = {
  arte: 'palette',
  ciencia: 'science',
  consciencia: 'psychology',
};

const labels = {
  arte:         { es: 'Arte',         en: 'Art' },
  ciencia:      { es: 'Ciencia',      en: 'Science' },
  consciencia:  { es: 'Consciencia',  en: 'Consciousness' },
};

const pillarVar = `--color-pillar-${pillar}`;

const styles = {
  backgroundColor: `rgb(from var(${pillarVar}) r g b / 0.1)`,
  color: `var(${pillarVar})`,
  borderColor: `rgb(from var(${pillarVar}) r g b / 0.3)`,
};
---

<span
  class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bitacora uppercase tracking-widest border"
  style={styles}
>
  <span class="material-symbols-outlined text-sm">{icons[pillar]}</span>
  {locale === 'en' ? labels[pillar].en : labels[pillar].es}
</span>
